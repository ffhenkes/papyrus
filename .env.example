# Papyrus Environment Configuration
# Copy this file to .env and customize as needed

# Ollama Configuration
# Specify which LLM model to use (must be available in Ollama)
# Common models: qwen3:8b, llama2:7b, mistral:7b, neural-chat:7b
OLLAMA_MODEL=qwen3:8b

# PDF File Configuration
# Path to the PDF file you want to analyze
PDF_FILE=pdfs/test.pdf

# Custom Analysis Prompt
# Define what you want the model to do with the PDF content
# Examples:
#   "Summarize this document in 3 paragraphs"
#   "Extract all dates and names from this document"
#   "What are the main findings in this document?"
CUSTOM_PROMPT="Summarize the key findings."
